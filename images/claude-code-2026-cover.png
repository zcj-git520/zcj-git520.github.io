<svg xmlns="http://www.w3.org/2000/svg" width="800" height="400" viewBox="0 0 800 400">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a1a2e"/>
      <stop offset="100%" style="stop-color:#16213e"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#00d9ff"/>
      <stop offset="100%" style="stop-color:#00ff88"/>
    </linearGradient>
  </defs>
  <rect width="800" height="400" fill="url(#bg)"/>
  <rect x="40" y="40" width="720" height="320" rx="20" fill="none" stroke="url(#accent)" stroke-width="2" opacity="0.3"/>
  <text x="400" y="180" font-family="Arial, sans-serif" font-size="48" font-weight="bold" fill="white" text-anchor="middle">Claude Code</text>
  <text x="400" y="230" font-family="Arial, sans-serif" font-size="24" fill="#00d9ff" text-anchor="middle">完全新手指南（2026版）</text>
  <text x="400" y="280" font-family="Arial, sans-serif" font-size="18" fill="#888" text-anchor="middle">从入门到精通</text>
  <circle cx="400" cy="330" r="30" fill="url(#accent)" opacity="0.8"/>
  <text x="400" y="340" font-family="Arial, sans-serif" font-size="32" fill="#1a1a2e" text-anchor="middle">›_</text>
</svg>