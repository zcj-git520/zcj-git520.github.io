<svg xmlns="http://www.w3.org/2000/svg" width="800" height="400" viewBox="0 0 800 400">
  <rect width="800" height="400" fill="#0d1117"/>
  <text x="400" y="50" font-family="Arial, sans-serif" font-size="20" fill="#fff" text-anchor="middle">Superpowers 推荐流程</text>
  
  <!-- Flow arrows and boxes -->
  <rect x="50" y="100" width="140" height="80" rx="10" fill="#238636" stroke="#238636" stroke-width="2"/>
  <text x="120" y="145" font-family="Arial, sans-serif" font-size="14" fill="#fff" text-anchor="middle">需求</text>
  
  <text x="220" y="145" font-family="Arial, sans-serif" font-size="24" fill="#58a6ff">→</text>
  
  <rect x="260" y="100" width="140" height="80" rx="10" fill="#1f6feb" stroke="#1f6feb" stroke-width="2"/>
  <text x="330" y="145" font-family="Arial, sans-serif" font-size="14" fill="#fff" text-anchor="middle">Brainstorm</text>
  
  <text x="430" y="145" font-family="Arial, sans-serif" font-size="24" fill="#58a6ff">→</text>
  
  <rect x="470" y="100" width="140" height="80" rx="10" fill="#8250df" stroke="#8250df" stroke-width="2"/>
  <text x="540" y="145" font-family="Arial, sans-serif" font-size="14" fill="#fff" text-anchor="middle">Writing Plans</text>
  
  <text x="640" y="145" font-family="Arial, sans-serif" font-size="24" fill="#58a6ff">→</text>
  
  <rect x="680" y="100" width="140" height="80" rx="10" fill="#d29922" stroke="#d29922" stroke-width="2"/>
  <text x="750" y="145" font-family="Arial, sans-serif" font-size="14" fill="#fff" text-anchor="middle">Execute</text>
  
  <text x="750" y="220" font-family="Arial, sans-serif" font-size="24" fill="#58a6ff">↓</text>
  
  <rect x="680" y="230" width="140" height="80" rx="10" fill="#f85149" stroke="#f85149" stroke-width="2"/>
  <text x="750" y="275" font-family="Arial, sans-serif" font-size="14" fill="#fff" text-anchor="middle">Code Review</text>
  
  <text x="610" y="275" font-family="Arial, sans-serif" font-size="24" fill="#58a6ff">←</text>
  
  <text x="400" y="360" font-family="Arial, sans-serif" font-size="16" fill="#888" text-anchor="middle">核心原则：拆分的小任务，不要一次就想完成一个项目</text>
</svg>