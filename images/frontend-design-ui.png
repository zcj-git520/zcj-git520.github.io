<svg xmlns="http://www.w3.org/2000/svg" width="800" height="400" viewBox="0 0 800 400">
  <rect width="800" height="400" fill="#0f172a"/>
  <rect x="0" y="0" width="800" height="28" fill="#1e293b"/>
  <circle cx="14" cy="14" r="6" fill="#ef4444"/>
  <circle cx="34" cy="14" r="6" fill="#f59e0b"/>
  <circle cx="54" cy="14" r="6" fill="#22c55e"/>
  <text x="80" y="18" font-family="monospace" font-size="11" fill="#64748b">frontend - Nuxt</text>
  
  <!-- Code structure -->
  <text x="20" y="70" font-family="monospace" font-size="13" fill="#06b6d4">function Card({ title, children }) {</text>
  <text x="40" y="100" font-family="monospace" font-size="13" fill="#22c55e">return (</text>
  <text x="60" y="130" font-family="monospace" font-size="13" fill="#f8fafc">&lt;div class="card"&gt;</text>
  <text x="80" y="160" font-family="monospace" font-size="13" fill="#f8fafc">&lt;h3&gt;{title}&lt;/h3&gt;</text>
  <text x="80" y="190" font-family="monospace" font-size="13" fill="#f8fafc">&lt;div class="content"&gt;</text>
  <text x="100" y="220" font-family="monospace" font-size="13" fill="#8b5cf6">{children}</text>
  <text x="80" y="250" font-family="monospace" font-size="13" fill="#f8fafc">&lt;/div&gt;</text>
  <text x="60" y="280" font-family="monospace" font-size="13" fill="#f8fafc">&lt;/div&gt;</text>
  <text x="40" y="310" font-family="monospace" font-size="13" fill="#22c55e">);</text>
  <text x="20" y="340" font-family="monospace" font-size="13" fill="#06b6d4">}</text>
  
  <!-- UI preview -->
  <rect x="450" y="80" width="320" height="260" rx="12" fill="#1e293b" stroke="#334155" stroke-width="1"/>
  <rect x="470" y="100" width="280" height="30" rx="6" fill="#3b82f6" opacity="0.8"/>
  <text x="530" y="120" font-family="Arial" font-size="14" fill="white" text-anchor="middle">Card Title</text>
  <rect x="470" y="145" width="180" height="12" rx="4" fill="#475569"/>
  <rect x="470" y="165" width="220" height="8" rx="4" fill="#334155"/>
  <rect x="470" y="180" width="200" height="8" rx="4" fill="#334155"/>
  
  <!-- Button -->
  <rect x="470" y="290" width="100" height="36" rx="8" fill="#3b82f6"/>
  <text x="520" y="314" font-family="Arial" font-size="13" fill="white" text-anchor="middle">Button</text>
</svg>