<svg xmlns="http://www.w3.org/2000/svg" width="800" height="400" viewBox="0 0 800 400">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e3a5f"/>
      <stop offset="100%" style="stop-color:#0f172a"/>
    </linearGradient>
  </defs>
  <rect width="800" height="400" fill="url(#bg)"/>
  <rect x="40" y="40" width="720" height="320" rx="20" fill="none" stroke="#22d3ee" stroke-width="2" opacity="0.4"/>
  <text x="400" y="160" font-family="Arial, sans-serif" font-size="52" font-weight="bold" fill="white" text-anchor="middle">Find Skills</text>
  <text x="400" y="220" font-family="Arial, sans-serif" font-size="22" fill="#22d3ee" text-anchor="middle">Claude Code 技能发现指南</text>
  <text x="400" y="260" font-family="Arial, sans-serif" font-size="16" fill="#94a3b8" text-anchor="middle">发现和安装 AI 能力扩展插件</text>
  
  <!-- Package icons -->
  <rect x="120" y="300" width="60" height="40" rx="6" fill="#8b5cf6" opacity="0.7"/>
  <text x="150" y="325" font-family="Arial" font-size="12" fill="white" text-anchor="middle">REACT</text>
  
  <rect x="200" y="300" width="60" height="40" rx="6" fill="#06b6d4" opacity="0.7"/>
  <text x="230" y="325" font-family="Arial" font-size="12" fill="white" text-anchor="middle">TEST</text>
  
  <rect x="280" y="300" width="60" height="40" rx="6" fill="#22c55e" opacity="0.7"/>
  <text x="310" y="325" font-family="Arial" font-size="12" fill="white" text-anchor="middle">DEPLOY</text>
  
  <rect x="360" y="300" width="60" height="40" rx="6" fill="#f59e0b" opacity="0.7"/>
  <text x="390" y="325" font-family="Arial" font-size="12" fill="white" text-anchor="middle">DOCS</text>
  
  <text x="520" y="320" font-family="monospace" font-size="20" fill="#22d3ee">npx skills</text>
  <text x="520" y="350" font-family="monospace" font-size="12" fill="#64748b">find | add | update</text>
</svg>